{
  "name": "eleventy-high-performance-blog",
  "version": "5.0.2",
  "license": "MIT",
  "description": "A starter repository for a blog web site using the Eleventy static site generator.",
  "scripts": {
    "build-ci": "npm run js-build && eleventy && npm run test",
    "build": "npm run clean && npm run build-ci",
    "watch": "concurrently \"npm run serve\" \"npm run js-build-watch\" \"npm run test-watch\"",
    "serve": "npm run clean && eleventy --serve",
    "js-build": "rollup -c rollup.config.js",
    "js-build-watch": "rollup -c rollup.config.js -w",
    "debug": "DEBUG=* eleventy && npm run test",
    "test": "vitest run",
    "test-watch": "vitest --watch",
    "clean": "rm -Rf ./_site/posts/*"
  },
  "pre-push": [],
  "pre-commit": [],
  "repository": {
    "type": "git",
    "url": "git://github.com/rynizx/Fortind.git"
  },
  "bugs": {
    "url": "https://github.com/rynizx/Fortind/issues"
  },
  "homepage": "https://github.com/rynizx/Fortind#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@rollup/plugin-terser": "^1.0.0",
    "eleventy-plugin-local-images": "^0.4.1",
    "file-type": "^22.0.1",
    "fs-extra": "^11.3.5",
    "jsdom": "^29.1.1",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "node-fetch": "^3.3.2",
    "pre-commit": "^2.0.0",
    "shorthash": "0.0.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@ampproject/toolbox-optimizer": "^2.10.1",
    "any-shell-escape": "^0.1.1",
    "clean-css": "^5.3.3",
    "concurrently": "^10.0.3",
    "csp-hash-generator": "0.0.3",
    "csso": "^5.0.5",
    "datauri": "^4.1.0",
    "expect.js": "^0.3.1",
    "ffmpeg-static": "^5.3.0",
    "hasha": "^7.0.0",
    "html-minifier-terser": "^7.2.0",
    "image-size": "^2.0.2",
    "lru-cache": "^11.3.6",
    "phin": "^4.0.0",
    "purge-from-html": "^1.0.3",
    "purgecss": "^8.0.0",
    "querystring": "^0.2.1",
    "rollup": "^4.60.3",
    "sharp": "^0.35.0",
    "touch": "^3.1.1"
  },
  "overrides": {
    "tough-cookie": ">=4.1.3",
    "terser": ">=5.14.2",
    "form-data": ">=4.0.1",
    "qs": ">=6.13.0",
    "minimatch": ">=3.1.2",
    "postcss": ">=8.4.31",
    "diff": ">=5.2.0",
    "html-minifier": "npm:html-minifier-terser@^7.0.0",
    "request": "npm:@cypress/request@^4.0.0"
  }
}
